#include <iostream>
#include <sstream>
#include <vector>
using namespace std;

int main(){
    string line;
    getline(cin,line);
    stringstream ss(line);
    vector<int> array;
    int x;
    while(ss>>x){
        array.push_back(x);
    }

    int n = array.size();
    for(int i=0;i<n-1;i++){
        bool isSwap=false;
        for(int j=0;j<n-i-1;j++){
            if(array[j]>array[j+1]){
                int temp;
                temp=array[j];
                array[j]=array[j+1];
                array[j+1]=temp;
                isSwap=true;
                /*
                ------USING STL------
                swap(array[j],array[j+1])
                */
            }
        }
        if(isSwap==false){  //Array is already sorted
            return 0 ;
        }
    }

    for(int x:array){
        cout<<x<< " " ;
    }
    return 0;
}

// Time Complexity : O(n^2)
// Space Complexity : O(n)
